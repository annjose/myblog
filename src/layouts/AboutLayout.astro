---
import type { MarkdownLayoutProps } from "astro";
import { Image } from "astro:assets";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Socials from "@/components/Socials.astro";
import Layout from "./Layout.astro";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import profilePhoto from "@/assets/images/ann-color-sketch-square.png";

interface AboutFrontmatter {
  title: string;
  name: string;
  tagline: string;
  interests: string[];
  currently: string;
  thirdPartyBio?: string[];
}

type Props = MarkdownLayoutProps<AboutFrontmatter>;

const { frontmatter } = Astro.props;
const linkedIn = SOCIALS.find(social => social.name === "LinkedIn");
const github = SOCIALS.find(social => social.name === "GitHub");
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <div class="mb-8 border-l-4 border-accent pl-5 sm:pl-6">
      {/* Hero: Photo + Name + Tagline */}
      <section class="mb-6 pt-6">
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
          <Image
            src={profilePhoto}
            alt={frontmatter.name}
            width={150}
            height={150}
            class="rounded-full"
          />
          <div class="text-center sm:text-left">
            <h1 class="text-2xl font-semibold tracking-wider sm:text-3xl">
              {frontmatter.name}
            </h1>
            <p class="mt-2 text-lg italic text-muted">
              {frontmatter.tagline}
            </p>
            <div class="mt-3 flex justify-center sm:justify-start">
              <Socials />
            </div>
          </div>
        </div>
      </section>

      {/* Third-party credentials bio */}
      {
        frontmatter.thirdPartyBio && frontmatter.thirdPartyBio.length > 0 && (
          <section class="mb-6 rounded-lg border border-border bg-accent/5 px-5 py-4">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-muted">
              Professional Background
            </p>
            <p class="leading-relaxed text-muted">{frontmatter.thirdPartyBio[0]}</p>
            <details class="group mt-4">
              <summary class="cursor-pointer text-sm font-medium text-accent underline decoration-dashed underline-offset-4">
                Read full professional background
              </summary>
              <div class="mt-4 space-y-3">
                {frontmatter.thirdPartyBio.slice(1).map((para: string) => (
                  <p class="leading-relaxed text-muted">{para}</p>
                ))}
              </div>
            </details>
            <div class="mt-5 flex flex-wrap gap-3 text-sm">
              {linkedIn && (
                <a
                  href={linkedIn.href}
                  class="rounded border border-accent/40 px-3 py-1.5 text-accent hover:bg-accent hover:text-background"
                >
                  LinkedIn profile
                </a>
              )}
              {github && (
                <a
                  href={github.href}
                  class="rounded border border-border px-3 py-1.5 hover:border-accent hover:text-accent"
                >
                  GitHub profile
                </a>
              )}
            </div>
          </section>
        )
      }

      {/* Current snapshot */}
      <section class="rounded-lg border border-border px-5 py-4">
        <h2 class="mb-3 text-xl font-semibold">Current Focus</h2>
        <p class="text-muted">{frontmatter.currently}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            frontmatter.interests.map((interest: string) => (
              <span class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-sm text-foreground">
                {interest}
              </span>
            ))
          }
        </div>
      </section>
    </div>

    {/* Bio: Markdown body */}
    <section
      id="about"
      class="app-prose mb-8 max-w-none prose-img:border-0"
    >
      <slot />
    </section>

  </main>
  <Footer />
</Layout>
