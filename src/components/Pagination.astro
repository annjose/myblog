---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;

// Derive base URL from current page URL so this works for /blog/ and /tags/foo/
const base = page.url.current.replace(/\/+$/, "").replace(/\/\d+$/, "");
const getPageUrl = (n: number) => (n === 1 ? `${base}/` : `${base}/${n}/`);

// Show at most 7 page numbers; use ellipsis for large ranges
const WINDOW = 2; // pages on each side of current
const pages: (number | "…")[] = [];
for (let i = 1; i <= page.lastPage; i++) {
  if (
    i === 1 ||
    i === page.lastPage ||
    Math.abs(i - page.currentPage) <= WINDOW
  ) {
    pages.push(i);
  } else if (
    pages[pages.length - 1] !== "…"
  ) {
    pages.push("…");
  }
}
---

{
  page.lastPage > 1 && (
    <nav
      class="mt-auto mb-8 flex items-center justify-center gap-1"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={["me-2 select-none", { "opacity-50": !page.url.prev }]}
        aria-label="Previous Page"
      >
        <IconArrowLeft class="inline-block rtl:rotate-180" />
        Prev
      </LinkButton>

      {pages.map(p =>
        p === "…" ? (
          <span class="px-1 text-muted select-none">…</span>
        ) : (
          <a
            href={getPageUrl(p)}
            aria-label={`Page ${p}`}
            aria-current={p === page.currentPage ? "page" : undefined}
            class:list={[
              "flex size-8 items-center justify-center rounded text-sm font-medium transition-colors",
              p === page.currentPage
                ? "bg-accent text-background"
                : "text-foreground hover:text-accent",
            ]}
          >
            {p}
          </a>
        )
      )}

      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={["ms-2 select-none", { "opacity-50": !page.url.next }]}
        aria-label="Next Page"
      >
        Next
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
