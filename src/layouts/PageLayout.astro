---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

interface PageFrontmatter {
  title: string;
  description?: string;
}

type Props = MarkdownLayoutProps<PageFrontmatter>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <h1 class="text-2xl font-semibold sm:text-3xl">{frontmatter.title}</h1>
    {frontmatter.description && (
      <p class="mt-2 mb-6 italic text-muted">{frontmatter.description}</p>
    )}
    <article class="app-prose mt-6 prose-img:border-0">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>
