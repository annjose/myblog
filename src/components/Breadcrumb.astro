---
type Props = { totalPages?: number };
const { totalPages } = Astro.props;

// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is Home > Blog > 1 <etc>
// replace Blog with Reflections (Page X of Y)
if (breadcrumbList[0] === "blog") {
  const pageNum = Number(breadcrumbList[1]) || 1;
  const suffix = totalPages ? `Page ${pageNum} of ${totalPages}` : `Page ${pageNum}`;
  breadcrumbList.splice(0, 2, `Reflections - ${suffix}`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (Page X of Y)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  const pageNum = Number(breadcrumbList[2]);
  const pageSuffix = pageNum === 1
    ? ""
    : totalPages ? ` - Page ${pageNum} of ${totalPages}` : ` (page ${pageNum})`;
  breadcrumbList.splice(1, 3, `${breadcrumbList[1]}${pageSuffix}`);
}
---

<nav class="app-layout mt-8 mb-6" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">Home</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["opacity-75", index === 0 ? "normal-case" : "capitalize lowercase"]}
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Tags > some-tag */}
              {decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${breadcrumb}/`} class="capitalize opacity-70">
              {breadcrumb}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
