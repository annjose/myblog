---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const startHereLinks = [
  {
    href: "/about/#my-story",
    title: "About / My Story",
    description: "My story, background, current focus, and how I work.",
  },
  {
    href: "/about/#projects",
    title: "Projects",
    description: "A few apps and experiments from my hands-on building phase.",
  },
  {
    href: "/talks/demystifying-ai/",
    title: "Demystifying AI",
    description: "An introductory session on AI that I gave at my local library.",
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 text-4xl font-bold sm:my-8 sm:text-5xl">
        {SITE.title}
      </h1>

      <p>
        Software builder, lifelong learner and engineering leader with 25+ years building web, mobile, and platform products. I love tinkering with technology, learning fundamentals,
        and writing about what I learn.
      </p>
      <p class="mt-2">
        Right now I'm building modern web apps with AI coding agents, experimenting with open-weights
        and on-device models, and learning how to work better with agentic tools.
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Connect with me:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="start-here" class="border-b border-border py-8">
      <h2 class="text-2xl font-semibold tracking-wide">Start here</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {
          startHereLinks.map(link => (
            <a
              href={link.href}
              class="rounded-lg border border-border px-4 py-3 hover:border-accent"
            >
              <h3 class="font-semibold text-accent">{link.title}</h3>
              <p class="mt-1 text-sm text-muted">{link.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/blog/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
